    "font_size": 16,
    "toolbar": {
      "breadcrumbs": false,
      "shell": "system",
      "dock": "bottom",
    },
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "agent": {
    "enabled": false,
  },
