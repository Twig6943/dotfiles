{
  "languages": {
    "C++": {
      "hard_tabs": true,
      "tab_size": 4,
    },
    "Editorconfig": {},
  },
  "buffer_line_height": "comfortable",
  "buffer_font_family": "Bitstream Vera Sans",
  "buffer_font_features": {
    "calt": false,
  },
